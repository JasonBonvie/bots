# =========================================
# BTC/Kalshi Momentum Bot Configuration
# =========================================

# Kalshi API Configuration (REQUIRED for contract prices)
# ========================================================
# Get your API credentials from: https://kalshi.com/account/api
#
# 1. Log into Kalshi
# 2. Go to Settings → API
# 3. Create a new API key
# 4. Copy the key and secret below

KALSHI_API_KEY=your_api_key_here
KALSHI_API_SECRET=your_api_secret_here

# Specific market ticker to track (optional)
# If not set, will auto-detect highest volume BTC market
# Examples: KXBTCD-25MAR19-T70500, KXBTC-25MAR19
KALSHI_MARKET_TICKER=

# Poll interval in seconds (default: 1.0)
# Lower = faster updates but more API calls
KALSHI_POLL_INTERVAL=1.0

# Use demo/paper trading API (for testing)
# Set to "true" to use demo-api.kalshi.co instead of production
KALSHI_USE_DEMO=false

# TradingView Configuration (for historical data)
# ================================================
# Used for 15-minute OHLCV data and technical indicators
# Optional - works without login but with limited data

# Session token (get from browser cookies after Gmail login)
# 1. Log into TradingView with Gmail
# 2. Open DevTools (F12) → Application → Cookies
# 3. Copy the "sessionid" cookie value
TV_SESSION_ID=

# Or use direct credentials (if you have a TradingView account)
TV_USERNAME=
TV_PASSWORD=

# Symbol to track for signals (default: BTCUSD on COINBASE)
TV_SYMBOL=COINBASE:BTCUSD

# Server Configuration
# ====================
HOST=0.0.0.0
PORT=8000

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
