# Kalshi API Configuration
# ========================
# 1. Save your RSA private key to: kalshi_private_key.pem
# 2. Set your API Key ID below

KALSHI_PRIVATE_KEY_PATH=kalshi_private_key.pem
KALSHI_API_KEY_ID=1ae7d33a-14c8-44da-9b81-0bf1a5f14bf0

# Optional: Specific market ticker (leave empty for auto-detect BTC markets)
KALSHI_MARKET_TICKER=

# Poll interval in seconds (lower = faster updates)
KALSHI_POLL_INTERVAL=0.5

# Which Kalshi API endpoint to use
KALSHI_USE_DEMO=false      # false = production API (real money)
                           # true = demo API (paper money on Kalshi's side)

# Whether the bot submits orders at all
KALSHI_LIVE_TRADING=true   # true = actually send orders to Kalshi
                           # false = simulate orders locally only (default)

# TradingView Configuration (for live BTC price)
TV_SYMBOL=BTCUSDT
TV_EXCHANGE=BINANCE
TV_POLL_INTERVAL=1.5
